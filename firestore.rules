rules_version = '2';

/* ===================================================================
   Katani Main Stage — Firestore Security Rules
   -------------------------------------------------------------------
   Data model:
     /users/{uid}          one doc per member/admin, doc id == Firebase Auth uid.
                            NOTE: no password field lives here — Firebase Auth
                            owns passwords (hashed, never readable by anyone).
     /collections/{id}     payment / fee / fine records (admin-entered).
     /minutes/{id}         meeting minutes (admin-only feature).
     /announcements/{id}   admin -> members broadcasts, with a `readBy` array
                            of uids that each member is allowed to append
                            themselves to (and nothing else on the doc).
     /documents/{id}       Group Documents (certificate, license, constitution,
                            fiscal plans) — each doc holds its own PDF as a
                            base64 data URL (no Firebase Storage — that now
                            requires a linked billing card, so files live
                            directly in Firestore instead, capped at ~700KB
                            raw per file to stay under Firestore's 1MiB
                            per-document limit).
     /settings/group       single document holding group-wide settings.

   The role check reads the requester's OWN /users/{uid} doc — this is the
   standard Firestore pattern for role-based rules without Cloud Functions
   / custom claims. It costs one extra document read per rule evaluation,
   which is negligible at this app's scale.
=================================================================== */
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return isSignedIn() && myProfile().role == 'admin';
    }
    // Secretary/Treasurer are ordinary members (role == 'member') with an extra
    // committeeRole flag — see auth.js createAdmin()/setCommitteeRole(). Using
    // .get() with a default means older member docs without the field simply
    // evaluate to '' (no committee access) instead of the rule erroring out.
    function isSecretary() {
      return isSignedIn() && myProfile().role == 'member' && myProfile().get('committeeRole', '') == 'secretary';
    }
    function isTreasurer() {
      return isSignedIn() && myProfile().role == 'member' && myProfile().get('committeeRole', '') == 'treasurer';
    }
    function isActive() {
      return isSignedIn() && myProfile().status == 'active';
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // True when this write only touches the given fields (used to let a
    // member "mark as read" without granting them write on the whole doc).
    function onlyChanges(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    // ---- users -------------------------------------------------------
    match /users/{uid} {
      // Any signed-in member/admin can read the directory (matches the
      // app's Members Directory, which both roles can view). No password
      // field ever lives in this collection, so this is safe to read.
      allow read: if isSignedIn();

      allow create:
        // Case 1: a brand-new account writing its OWN profile doc right
        // after Firebase Auth sign-up (public self-registration). Forcing
        // role == 'member' here is what stops a crafted client request
        // from ever self-granting admin — this is enforced server-side,
        // not just in the app's JS.
        if (isSelf(uid)
            && request.resource.data.role == 'member'
            && request.resource.data.status in ['active', 'pending'])
        // Case 2: an existing admin creating a profile doc for someone
        // they just registered via the Admin Dashboard (member, Secretary,
        // Treasurer, or another admin).
        || isAdmin()
        // Case 3: the Secretary adding a new member via Members Directory.
        // Restricted to plain members — the Secretary can never grant admin
        // or a committeeRole (that privilege escalation stays admin-only).
        || (isSecretary()
            && request.resource.data.role == 'member'
            && request.resource.data.get('committeeRole', '') == '');

      allow update:
        // Admin can edit anything (approve/reject, promote/demote, edit
        // member details, assign/revoke Secretary or Treasurer).
        if isAdmin()
        // A member may edit their own non-privileged fields, but can
        // never touch their own role, committeeRole, status, or email
        // from the client.
        || (isSelf(uid) && onlyChanges([
              'name','phone','altPhone','photo','dob','gender',
              'nationalId','residence','motorcycle','nextOfKin',
              'mustChangePassword'
            ]))
        // The Secretary can edit any member's directory profile fields
        // (Members Directory "Edit" action — same field set editMember()
        // writes) but can't touch role/committeeRole/email/mustChangePassword.
        || (isSecretary() && onlyChanges([
              'name','phone','status','dob','gender',
              'nationalId','residence','saccoNumber','motorcycle',
              'nextOfKin','photo'
            ]));

      allow delete: if isAdmin();
    }

    // ---- collections (payments / fees / fines) ------------------------
    match /collections/{id} {
      // A member may only read their own payment records; admin/Treasurer read all.
      allow read: if isAdmin() || isTreasurer() || (isActive() && resource.data.memberUid == request.auth.uid);
      // Admins and the Treasurer record/edit/delete collections (matches the
      // app's Record Payment / Welfare Contributions screens — the Treasurer's
      // only two features).
      allow create, update, delete: if isAdmin() || isTreasurer();
    }

    // ---- meeting minutes -----------------------------------------------
    match /minutes/{id} {
      allow read, write: if isAdmin() || isSecretary();
    }

    // ---- announcements ---------------------------------------------------
    match /announcements/{id} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isSecretary();
      allow delete: if isAdmin();
      allow update: if isAdmin() || isSecretary() || (isSignedIn() && onlyChanges(['readBy']));
    }

    // ---- group documents (certificate / license / constitution / fiscal plans) ----
    match /documents/{id} {
      // Every signed-in member/admin can see and download the group's
      // official documents — matches the Group Documents page, which is
      // read-only for plain members.
      allow read: if isSignedIn();
      // Only admin or Secretary can upload/replace/remove documents.
      allow create, update, delete: if isAdmin() || isSecretary();
    }

    // ---- group settings --------------------------------------------------
    match /settings/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
